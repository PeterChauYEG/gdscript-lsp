{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(func|if|elif|else|for|while|match|class|class_name|signal).*:\\s*$",
    "decreaseIndentPattern": "^\\s*(pass|break|continue|return)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": ":\\s*$",
      "action": { "indentAction": "indent" }
    }
  ]
}
